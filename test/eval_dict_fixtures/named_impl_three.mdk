-- @Impl three-impl disambiguation (mirror the @First/@Second/@Third spec case):
-- three impls of `Pick Int` share head tycon `Int`; each hint picks its named impl.
interface Pick a where
  pick : a -> a -> a

impl First of Pick Int where
  pick x y = x

impl Second of Pick Int where
  pick x y = y

impl Third of Pick Int where
  pick x y = x + y

main = putStrLn (intToString (pick @First 3 4) ++ " " ++ intToString (pick @Second 3 4) ++ " " ++ intToString (pick @Third 3 4))
