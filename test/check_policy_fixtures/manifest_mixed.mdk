-- WS-1c manifest gate fixture: multi-label manifest ORDERING.
-- Every effect label is a host capability, so a function's whole verified row
-- lands in the manifest — this fixture checks that a two-label row emits BOTH
-- entries, sorted ascending.
-- `writeOut` uses Stdout (putStr → <Stdout>).
-- `tick` uses Clock (wallTimeSec → <Clock>).
-- `entry` calls both, so its inferred row is <Clock, Stdout>.
-- The manifest of `entry` must be (labels sorted ascending; both ⊤-param → true):
--   [package.capabilities]
--   Clock = true
--   Stdout = true

writeOut : String -> <Stdout> Unit
writeOut s = putStr s

tick : <Clock> Float
tick = wallTimeSec ()

entry : String -> <Clock, Stdout> Unit
entry s =
  let _ = tick
  writeOut s
