-- WS-4 PRODUCT reject: HOST out of prefix.  The extern fetches host
-- "other.com/api" (NOT under the bound's "idp.example.com/*" prefix); the method
-- is in-set.  Host axis escapes => REJECT (performs the narrow product).
effect Net Product

extern fetch : String -> <Net Host="other.com/api" Method={"GET"}> String

call : Unit -> <Net Host="idp.example.com/*" Method={"GET", "POST"}> String
call _ = fetch "x"

main : <IO> Unit
main = println "should not typecheck"
