-- A `||`-chain with a trailing comment per operand.  Reflowing the body by
-- width would shift each comment down an operand and merge the last two
-- (finding "L"), so the verbatim safety-net emits this decl's source unchanged.
identChar c =
  (c >= 48 && c <= 57)        -- 0-9
  || (c >= 65 && c <= 90)     -- A-Z
  || (c >= 97 && c <= 122)    -- a-z
  || c == 95                  -- _
