-- string interpolation (\{e} desugars to display e) over builtin + nested types
data Color = Red | Green deriving (Debug)
greet name n = "hi \{name}, you have \{n} messages"
main =
  ( "val=\{40 + 2} ok=\{True}"
  , "\{[1, 2, 3]} items, first \{Some 9}"
  , greet "sam" 3
  , "color=\{Red} vs \{Green}"
  , "nested \{(1, "two", 'c')}"
  )
